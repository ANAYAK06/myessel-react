<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!--
      Serve index.html for any URL that does not match a physical file or directory.
      Uses IIS built-in httpErrors — no URL Rewrite module required.
      This fixes the 500 error caused by the missing URL Rewrite module.
    -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>
  </system.webServer>
</configuration>
